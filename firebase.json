{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "naco-d2738",
          "appId": "1:637970082188:android:5826df17b039c5a3444ea9",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "naco-d2738",
          "configurations": {
            "android": "1:637970082188:android:5826df17b039c5a3444ea9",
            "ios": "1:637970082188:ios:df5adc32bc9703e4444ea9",
            "macos": "1:637970082188:ios:df5adc32bc9703e4444ea9",
            "web": "1:637970082188:web:57304b8bf42aa244444ea9",
            "windows": "1:637970082188:web:5a8ada8d2e741949444ea9"
          }
        }
      }
    }
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/profile**",
        "destination": "/profile.html"
      },
      {
        "source": "/p/**",
        "destination": "/profile.html"
      }
    ],
    "headers": [
      {
        "source": "/profile.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600, must-revalidate"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/xml; charset=utf-8"
          }
        ]
      },
      {
        "source": "/sitemap-profiles.xml",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/xml; charset=utf-8"
          }
        ]
      },
      {
        "source": "/robots.txt",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      }
    ]
  }
}
